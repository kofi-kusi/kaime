MAIL_USERNAME="your-smtp-username"
MAIL_PASSWORD="your-smtp-password"
MAIL_FROM="noreply@example.edu"
MAIL_PORT=587
MAIL_SERVER="smtp.example.edu"
MAIL_FROM_NAME="Academic Notifications"
MAIL_STARTTLS=true
MAIL_SSL_TLS=false
USE_CREDENTIALS=true
VALIDATE_CERTS=true

POSTGRES_SERVER=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=academic_notifications

NOTIFICATION_SCAN_INTERVAL_MINUTES=30
NOTIFICATION_LOOKAHEAD_DAYS=14
NOTIFICATION_MAX_RETRIES=3
NOTIFICATION_RETRY_BACKOFF_SECONDS=3
NOTIFICATION_TIMEZONE="UTC"
